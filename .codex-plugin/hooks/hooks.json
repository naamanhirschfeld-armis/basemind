{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-.}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CODEX_PLUGIN_ROOT:-.}/hooks/run-hook.cmd\" inbox-notify",
            "async": false
          }
        ]
      }
    ]
  }
}
